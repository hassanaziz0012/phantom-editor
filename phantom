#!/bin/bash

# Base directory of the project codebase.
# Currently set to the development folder.
# Change this to /opt/phantom-editor when deploying to production.
BASE_DIR="/home/hassan/programming/phantom-editor"

show_usage() {
    echo "Usage: phantom <command> [arguments]"
    echo "Commands:"
    echo "  audio process [-R|--recursive] <path>"
    echo "  edit add_bgm <path_to_video> <bgm_track> [--volume <percentage>]"
    echo "  edit attach-webcam-mask --screen <screen_video> --webcam <webcam_video> [arguments]"
    echo "  edit auto-attach-webcam --screen <screen_video> --webcam <webcam_video> [arguments]"
    echo "  edit caption <video_path> [arguments]"
    echo "  edit transcribe <video_path> [arguments]"
    echo "  edit trim-silences <video_path> [arguments]"
    echo "  filmora detect-silence <path_to_mp4>"
    echo "  tweet [--image] <tweet_content>"
    echo "  yt upload <video_path>"
    echo "  yt recommend-related (--metadata <path> | --video-id <id>) [--limit <int>] [--json]"
    echo "  yt create-metadata <video_path>"
    echo "  yt count-uploads [<channel>] [--fresh]"
    echo "  shorts metadata create <folder_path> [arguments]"
    echo "  shorts metadata clean"
    echo "  shorts upload --platform <youtube|instagram|tiktok|all> <video_path>"
    echo "  shorts add-thumbnail [arguments] <video_path>"
    echo "  shorts trim [arguments]"
    echo "  docs open"
}

if [ $# -eq 0 ]; then
    show_usage
    exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
    audio)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "process" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom audio process [-R|--recursive] <path>"
                exit 1
            fi
            "$BASE_DIR/audio-processing/process_audio.sh" "$@"
        else
            echo "Unknown audio subcommand: $SUBCOMMAND"
            echo "Usage: phantom audio process [-R|--recursive] <path>"
            exit 1
        fi
        ;;
    edit)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "add_bgm" ]; then
            "$BASE_DIR/video-editing/add_bgm_to_video.sh" "$@"
        elif [ "$SUBCOMMAND" = "attach-webcam-mask" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom edit attach-webcam-mask --screen <screen_video> --webcam <webcam_video> [arguments]"
                exit 1
            fi
            uv run --project "$BASE_DIR" python "$BASE_DIR/video-editing/attach_webcam_mask.py" "$@"
        elif [ "$SUBCOMMAND" = "auto-attach-webcam" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom edit auto-attach-webcam --screen <screen_video> --webcam <webcam_video> [arguments]"
                exit 1
            fi
            uv run --project "$BASE_DIR" python "$BASE_DIR/video-editing/auto_attach_webcam_mask.py" "$@"
        elif [ "$SUBCOMMAND" = "caption" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom edit caption <video_path> [arguments]"
                exit 1
            fi
            uv run --project "$BASE_DIR" python "$BASE_DIR/video-editing/auto_caption.py" "$@"
        elif [ "$SUBCOMMAND" = "transcribe" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom edit transcribe <video_path> [arguments]"
                exit 1
            fi
            uv run --project "$BASE_DIR" python "$BASE_DIR/video-editing/transcribe.py" "$@"
        elif [ "$SUBCOMMAND" = "trim-silences" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom edit trim-silences <video_path> [arguments]"
                exit 1
            fi
            uv run --project "$BASE_DIR" python "$BASE_DIR/video-editing/trim_silences.py" "$@"
        else
            echo "Unknown edit subcommand: $SUBCOMMAND"
            echo "Usage: phantom edit add_bgm <path_to_video> <bgm_track> [--volume <percentage>]"
            echo "       phantom edit attach-webcam-mask --screen <screen_video> --webcam <webcam_video> [arguments]"
            echo "       phantom edit auto-attach-webcam --screen <screen_video> --webcam <webcam_video> [arguments]"
            echo "       phantom edit caption <video_path> [arguments]"
            echo "       phantom edit transcribe <video_path> [arguments]"
            echo "       phantom edit trim-silences <video_path> [arguments]"
            exit 1
        fi
        ;;
    filmora)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "detect-silence" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom filmora detect-silence <path_to_mp4>"
                exit 1
            fi
            SCRIPT_PATH=$(wslpath -w "$BASE_DIR/filmora-automation/filmora_silence_detection.py")
            python.exe "$SCRIPT_PATH" "$1"
        else
            echo "Unknown filmora subcommand: $SUBCOMMAND"
            echo "Usage: phantom filmora detect-silence <path_to_mp4>"
            exit 1
        fi
        ;;
    tweet)
        if [ $# -eq 0 ]; then
            echo "Usage: phantom tweet [--image] <tweet_content>"
            exit 1
        fi
        "$BASE_DIR/twitter/tweet.sh" "$@"
        ;;
    yt)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "upload" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/youtube_api/upload_video.py" "$@"
        elif [ "$SUBCOMMAND" = "recommend-related" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/youtube_api/recommend_related_videos.py" "$@"
        elif [ "$SUBCOMMAND" = "create-metadata" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/youtube_api/create_metadata.py" "$@"
        elif [ "$SUBCOMMAND" = "count-uploads" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/youtube_api/count_youtube_uploads.py" "$@"
        else
            echo "Unknown yt subcommand: $SUBCOMMAND"
            echo "Usage: phantom yt upload <video_path>"
            echo "       phantom yt recommend-related (--metadata <path> | --video-id <id>) [--limit <int>] [--json]"
            echo "       phantom yt create-metadata <video_path>"
            echo "       phantom yt count-uploads [<channel>] [--fresh]"
            exit 1
        fi
        ;;
    shorts)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "metadata" ]; then
            METADATA_CMD="$1"
            shift
            if [ "$METADATA_CMD" = "create" ]; then
                if [ $# -eq 0 ]; then
                    echo "Usage: phantom shorts metadata create <folder_path> [arguments]"
                    exit 1
                fi
                uv run --project "$BASE_DIR" python "$BASE_DIR/shorts/create_bulk_metadata.py" "$@"
            elif [ "$METADATA_CMD" = "clean" ]; then
                uv run --project "$BASE_DIR" python "$BASE_DIR/shorts/clean_metadata.py" "$@"
            else
                echo "Unknown shorts metadata subcommand: $METADATA_CMD"
                echo "Usage: phantom shorts metadata create <folder_path> [arguments]"
                echo "       phantom shorts metadata clean"
                exit 1
            fi
        elif [ "$SUBCOMMAND" = "upload" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/shorts/upload.py" "$@"
        elif [ "$SUBCOMMAND" = "add-thumbnail" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/shorts/add_thumbnail.py" "$@"
        elif [ "$SUBCOMMAND" = "trim" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/shorts/auto_trim_shorts.py" "$@"
        else
            echo "Unknown shorts subcommand: $SUBCOMMAND"
            echo "Usage: phantom shorts metadata create <folder_path> [arguments]"
            echo "       phantom shorts metadata clean"
            echo "       phantom shorts upload --platform <youtube|instagram|tiktok|all> <video_path>"
            echo "       phantom shorts add-thumbnail [arguments] <video_path>"
            echo "       phantom shorts trim [arguments]"
            exit 1
        fi
        ;;
    docs)
        SUBCOMMAND="$1"
        shift
        
        open_url() {
            local url="$1"
            if command -v explorer.exe >/dev/null 2>&1; then
                explorer.exe "$url" >/dev/null 2>&1 || true
            elif command -v xdg-open >/dev/null 2>&1; then
                xdg-open "$url" >/dev/null 2>&1 || true
            else
                python3 -m webbrowser "$url" >/dev/null 2>&1 || true
            fi
        }

        if [ "$SUBCOMMAND" = "open" ]; then
            # Check if port 8000 is already in use
            if python3 -c "import socket; s = socket.socket(socket.AF_INET, socket.SOCK_STREAM); s.settimeout(1); s.connect(('127.0.0.1', 8000))" 2>/dev/null; then
                echo "Docs server is already running on http://127.0.0.1:8000"
                echo "Opening browser..."
                open_url "http://127.0.0.1:8000"
                exit 0
            else
                echo "Starting docs server on http://127.0.0.1:8000..."
                uv run --project "$BASE_DIR" mkdocs serve &
                SERVER_PID=$!
                
                # Set trap to ensure server is cleaned up when script exits
                trap 'kill $SERVER_PID 2>/dev/null' EXIT INT TERM
                
                # Wait 2 seconds for server to start
                sleep 2
                
                echo "Opening browser..."
                open_url "http://127.0.0.1:8000"
                
                # Keep script running to show server output
                wait $SERVER_PID
            fi
        else
            echo "Unknown docs subcommand: $SUBCOMMAND"
            echo "Usage: phantom docs open"
            exit 1
        fi
        ;;
    *)
        echo "Unknown command: $COMMAND"
        show_usage
        exit 1
        ;;
esac
