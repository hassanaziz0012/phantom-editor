#!/bin/bash

# Base directory of the project codebase.
# Currently set to the development folder.
# Change this to /opt/phantom-editor when deploying to production.
BASE_DIR="/home/hassan/programming/phantom-editor"

show_usage() {
    echo "Usage: phantom <command> [arguments]"
    echo "Commands:"
    echo "  audio process <path_to_mp4>"
    echo "  edit add_bgm <path_to_video> <bgm_track> [--volume <percentage>]"
    echo "  filmora detect-silence <path_to_mp4>"
    echo "  tweet <tweet_content>"
    echo "  tts speak <text>"
    echo "  tts save <text> [--output-dir <dir>]"
    echo "  youtube upload <video_path>"
    echo "  youtube recommend-related (--metadata <path> | --video-id <id>) [--limit <int>] [--json]"
    echo "  youtube create-metadata <video_path>"
}

if [ $# -eq 0 ]; then
    show_usage
    exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
    audio)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "process" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom audio process <path_to_mp4>"
                exit 1
            fi
            "$BASE_DIR/audio-processing/process_audio.sh" "$1"
        else
            echo "Unknown audio subcommand: $SUBCOMMAND"
            echo "Usage: phantom audio process <path_to_mp4>"
            exit 1
        fi
        ;;
    edit)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "add_bgm" ]; then
            "$BASE_DIR/video-editing/add_bgm_to_video.sh" "$@"
        else
            echo "Unknown edit subcommand: $SUBCOMMAND"
            echo "Usage: phantom edit add_bgm <path_to_video> <bgm_track> [--volume <percentage>]"
            exit 1
        fi
        ;;
    filmora)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "detect-silence" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom filmora detect-silence <path_to_mp4>"
                exit 1
            fi
            SCRIPT_PATH=$(wslpath -w "$BASE_DIR/filmora-automation/filmora_silence_detection.py")
            python.exe "$SCRIPT_PATH" "$1"
        else
            echo "Unknown filmora subcommand: $SUBCOMMAND"
            echo "Usage: phantom filmora detect-silence <path_to_mp4>"
            exit 1
        fi
        ;;
    tweet)
        if [ $# -eq 0 ]; then
            echo "Usage: phantom tweet <tweet_content>"
            exit 1
        fi
        "$BASE_DIR/twitter/tweet.sh" "$*"
        ;;
    tts)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "speak" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom tts speak <text>"
                exit 1
            fi
            # Using uv to run the python script with the project's virtual environment
            uv run --project "$BASE_DIR" python "$BASE_DIR/kokoro-tts/makesound.py" "$@"
        elif [ "$SUBCOMMAND" = "save" ]; then
            if [ $# -eq 0 ]; then
                echo "Usage: phantom tts save <text> [--output-dir <dir>]"
                exit 1
            fi
            uv run --project "$BASE_DIR" python "$BASE_DIR/kokoro-tts/savesound.py" "$@"
        else
            echo "Unknown tts subcommand: $SUBCOMMAND"
            echo "Usage: phantom tts speak <text>"
            echo "       phantom tts save <text> [--output-dir <dir>]"
            exit 1
        fi
        ;;
    youtube)
        SUBCOMMAND="$1"
        shift
        if [ "$SUBCOMMAND" = "upload" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/youtube-api/upload_video.py" "$@"
        elif [ "$SUBCOMMAND" = "recommend-related" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/youtube-api/recommend_related_videos.py" "$@"
        elif [ "$SUBCOMMAND" = "create-metadata" ]; then
            uv run --project "$BASE_DIR" python "$BASE_DIR/youtube-api/create_metadata.py" "$@"
        else
            echo "Unknown youtube subcommand: $SUBCOMMAND"
            echo "Usage: phantom youtube upload <video_path>"
            echo "       phantom youtube recommend-related (--metadata <path> | --video-id <id>) [--limit <int>] [--json]"
            echo "       phantom youtube create-metadata <video_path>"
            exit 1
        fi
        ;;
    *)
        echo "Unknown command: $COMMAND"
        show_usage
        exit 1
        ;;
esac
